<!-- Interactive Preview section -->
<section id="preview" class="screen pt-20 pb-12 lg:pt-0 lg:pb-0">
  <div class="screen-inner w-full max-w-[1120px] mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-6 items-start lg:items-center">
    <!-- Controls panel -->
    <div class="p-5 sm:p-6 rounded-2xl border border-zinc-200/70 dark:border-zinc-800 bg-white/60 dark:bg-zinc-900/50 backdrop-blur-sm" data-reveal>
      <header>
        <p class="text-brand-600 dark:text-brand-400 text-xs font-bold tracking-[0.08em] uppercase mb-2">Interactive Popup Preview</p>
        <h2 class="font-display text-xl sm:text-2xl lg:text-[clamp(1.5rem,2.8vw,2.25rem)] leading-[1.1] tracking-tight max-w-[22ch]">Adjust settings and watch subtitles update live</h2>
      </header>

      <div class="mt-4 sm:mt-5 space-y-3 sm:space-y-4">
        <div data-reveal data-delay="60">
          <label for="previewProvider" class="block text-xs font-semibold mb-1.5">Translation provider</label>
          <select id="previewProvider" class="w-full rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800/60 text-sm max-sm:text-base px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500/40 transition-shadow">
            <option value="auto">Auto fallback (Recommended)</option>
            <option value="google">Google translate endpoint</option>
            <option value="libre">LibreTranslate public mirrors</option>
            <option value="apertium">Apertium APY</option>
            <option value="mymemory">MyMemory</option>
          </select>
        </div>

        <div data-reveal data-delay="100">
          <label for="previewLanguage" class="block text-xs font-semibold mb-1.5">Target language</label>
          <select id="previewLanguage" class="w-full rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800/60 text-sm max-sm:text-base px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500/40 transition-shadow">
            <option value="af">🇿🇦 Afrikaans</option>
            <option value="sq">🇦🇱 Albanian</option>
            <option value="am">🇪🇹 Amharic</option>
            <option value="ar">🇸🇦 Arabic</option>
            <option value="hy">🇦🇲 Armenian</option>
            <option value="az">🇦🇿 Azerbaijani</option>
            <option value="eu">🇪🇸 Basque</option>
            <option value="be">🇧🇾 Belarusian</option>
            <option value="bn">🇧🇩 Bengali</option>
            <option value="bs">🇧🇦 Bosnian</option>
            <option value="bg">🇧🇬 Bulgarian</option>
            <option value="ca">🇪🇸 Catalan</option>
            <option value="zh">🇨🇳 Chinese</option>
            <option value="hr">🇭🇷 Croatian</option>
            <option value="cs">🇨🇿 Czech</option>
            <option value="da">🇩🇰 Danish</option>
            <option value="nl">🇳🇱 Dutch</option>
            <option value="en">🇬🇧 English</option>
            <option value="eo">🌐 Esperanto</option>
            <option value="et">🇪🇪 Estonian</option>
            <option value="tl">🇵🇭 Filipino</option>
            <option value="fi">🇫🇮 Finnish</option>
            <option value="fr">🇫🇷 French</option>
            <option value="gl">🇪🇸 Galician</option>
            <option value="ka">🇬🇪 Georgian</option>
            <option value="de">🇩🇪 German</option>
            <option value="el">🇬🇷 Greek</option>
            <option value="gu">🇮🇳 Gujarati</option>
            <option value="ht">🇭🇹 Haitian Creole</option>
            <option value="he">🇮🇱 Hebrew</option>
            <option value="hi">🇮🇳 Hindi</option>
            <option value="hu">🇭🇺 Hungarian</option>
            <option value="is">🇮🇸 Icelandic</option>
            <option value="id">🇮🇩 Indonesian</option>
            <option value="ga">🇮🇪 Irish</option>
            <option value="it">🇮🇹 Italian</option>
            <option value="ja">🇯🇵 Japanese</option>
            <option value="kn">🇮🇳 Kannada</option>
            <option value="kk">🇰🇿 Kazakh</option>
            <option value="ko">🇰🇷 Korean</option>
            <option value="lv">🇱🇻 Latvian</option>
            <option value="lt">🇱🇹 Lithuanian</option>
            <option value="ms">🇲🇾 Malay</option>
            <option value="mr">🇮🇳 Marathi</option>
            <option value="mn">🇲🇳 Mongolian</option>
            <option value="ne">🇳🇵 Nepali</option>
            <option value="no">🇳🇴 Norwegian</option>
            <option value="fa">🇮🇷 Persian</option>
            <option value="pl">🇵🇱 Polish</option>
            <option value="pt">🇵🇹 Portuguese</option>
            <option value="pa">🇮🇳 Punjabi</option>
            <option value="ro">🇷🇴 Romanian</option>
            <option value="ru">🇷🇺 Russian</option>
            <option value="gd">🏴 Scottish Gaelic</option>
            <option value="sr">🇷🇸 Serbian</option>
            <option value="si">🇱🇰 Sinhala</option>
            <option value="sk">🇸🇰 Slovak</option>
            <option value="sl">🇸🇮 Slovenian</option>
            <option value="es" selected>🇪🇸 Spanish</option>
            <option value="sw">🇰🇪 Swahili</option>
            <option value="sv">🇸🇪 Swedish</option>
            <option value="ta">🇮🇳 Tamil</option>
            <option value="te">🇮🇳 Telugu</option>
            <option value="th">🇹🇭 Thai</option>
            <option value="tr">🇹🇷 Turkish</option>
            <option value="uk">🇺🇦 Ukrainian</option>
            <option value="ur">🇵🇰 Urdu</option>
            <option value="uz">🇺🇿 Uzbek</option>
            <option value="vi">🇻🇳 Vietnamese</option>
            <option value="cy">🏴 Welsh</option>
            <option value="yi">🌐 Yiddish</option>
            <option value="yo">🇳🇬 Yoruba</option>
            <option value="zu">🇿🇦 Zulu</option>
          </select>
        </div>

        <div data-reveal data-delay="140">
          <label for="previewReplacement" class="block text-xs font-semibold mb-1.5">Replacement percentage</label>
          <div class="flex items-center gap-3">
            <input id="previewReplacement" class="control-range flex-1 h-2 rounded-full appearance-none bg-brand-100 dark:bg-brand-900/40 accent-brand-600 cursor-pointer" type="range" min="1" max="100" step="1" value="35" />
            <output id="previewReplacementValue" class="min-w-[40px] text-right text-brand-700 dark:text-brand-400 text-sm font-bold tabular-nums" for="previewReplacement">35%</output>
          </div>
        </div>

        <div class="flex items-center justify-between rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800/60 px-3 py-2.5" data-reveal data-delay="180">
          <label for="previewEnabled" class="text-xs font-semibold">Enable Lingo Stream</label>
          <input id="previewEnabled" type="checkbox" checked class="w-4.5 h-4.5 accent-brand-600 cursor-pointer" />
        </div>

        <div data-reveal data-delay="220">
          <label for="previewCustomSentence" class="block text-xs font-semibold mb-1.5">Live subtitle sentence</label>
          <textarea id="previewCustomSentence" class="w-full min-h-[72px] sm:min-h-[82px] rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800/60 text-sm max-sm:text-base px-3 py-2.5 leading-relaxed resize-y focus:outline-none focus:ring-2 focus:ring-brand-500/40 transition-shadow" rows="3" placeholder="Type a sentence and Lingo Stream will enrich it live.">I really enjoy learning new skills every day.</textarea>
          <div class="flex flex-wrap gap-2 mt-2" role="group" aria-label="Quick sentence presets">
            <button type="button" class="pill-btn rounded-full border border-brand-500/25 bg-brand-500/[0.06] text-brand-700 dark:text-brand-400 text-[11px] font-bold px-3 py-1.5 cursor-pointer hover:-translate-y-px hover:bg-brand-500/10 transition-all" data-phrase="I really enjoy learning new skills every day.">Daily skills</button>
            <button type="button" class="pill-btn rounded-full border border-brand-500/25 bg-brand-500/[0.06] text-brand-700 dark:text-brand-400 text-[11px] font-bold px-3 py-1.5 cursor-pointer hover:-translate-y-px hover:bg-brand-500/10 transition-all" data-phrase="Watching videos helps me build language confidence quickly.">Confidence boost</button>
            <button type="button" class="pill-btn rounded-full border border-brand-500/25 bg-brand-500/[0.06] text-brand-700 dark:text-brand-400 text-[11px] font-bold px-3 py-1.5 cursor-pointer hover:-translate-y-px hover:bg-brand-500/10 transition-all max-sm:hidden" data-phrase="I practice speaking with friends and review new vocabulary at night.">Speaking routine</button>
          </div>
        </div>
      </div>

      <div class="mt-4 sm:mt-5 flex gap-3 max-sm:flex-col" data-reveal data-delay="260">
        <button type="button" class="btn btn-primary flex-1 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white text-sm font-bold px-4 py-2.5 text-center shadow-sm hover:-translate-y-px transition-all" data-preview-save>Save Settings</button>
        <button type="button" class="btn btn-ghost flex-1 rounded-xl border border-brand-500/25 bg-brand-500/[0.06] text-brand-700 dark:text-brand-400 text-sm font-bold px-4 py-2.5 text-center hover:-translate-y-px transition-all" data-preview-refresh>Refresh Captions</button>
      </div>
    </div>

    <!-- Output panel -->
    <div class="p-5 sm:p-6 rounded-2xl border border-zinc-200/70 dark:border-zinc-800 bg-white/70 dark:bg-zinc-900/60 backdrop-blur-sm" data-reveal data-delay="110">
      <p id="previewMeta" class="text-brand-700 dark:text-brand-400 text-xs font-bold">
        Provider: Auto fallback (Recommended) — Target: Spanish — Replaced words: 1
      </p>
      <div class="mt-4 grid grid-cols-3 gap-3">
        <article class="p-3 rounded-xl border border-brand-500/15 bg-white/80 dark:bg-zinc-800/50">
          <span class="block text-[11px] text-zinc-500 dark:text-zinc-400 font-semibold">Coverage</span>
          <strong id="previewDensity" class="block mt-1 font-display text-brand-700 dark:text-brand-400 text-lg">20%</strong>
        </article>
        <article class="p-3 rounded-xl border border-brand-500/15 bg-white/80 dark:bg-zinc-800/50">
          <span class="block text-[11px] text-zinc-500 dark:text-zinc-400 font-semibold">Total words</span>
          <strong id="previewWordCount" class="block mt-1 font-display text-brand-700 dark:text-brand-400 text-lg">8</strong>
        </article>
        <article class="p-3 rounded-xl border border-brand-500/15 bg-white/80 dark:bg-zinc-800/50">
          <span class="block text-[11px] text-zinc-500 dark:text-zinc-400 font-semibold">Status</span>
          <strong id="previewStatus" class="block mt-1 font-display text-brand-700 dark:text-brand-400 text-lg">Active</strong>
        </article>
      </div>
      <div class="mt-4 p-3 sm:p-4 rounded-xl border border-zinc-200/70 dark:border-zinc-800 bg-white dark:bg-zinc-900">
        <p class="leading-relaxed text-sm sm:text-base">
          <span class="inline-block mr-2 text-zinc-400 text-[11px] tracking-wider uppercase font-extrabold">Original</span>
          <span id="previewOriginalLine">I really enjoy learning new skills every day.</span>
        </p>
        <p class="mt-3 leading-relaxed text-sm sm:text-base">
          <span class="inline-block mr-2 text-brand-600 dark:text-brand-400 text-[11px] tracking-wider uppercase font-extrabold">Lingo Stream</span>
          <span id="previewTranslatedLine" class="translated-line" aria-live="polite">
            I really enjoy learning new <span class="word-pair">skills <span class="translation">(habilidades)</span></span> every day.
          </span>
        </p>
      </div>
    </div>
  </div>
</section>
